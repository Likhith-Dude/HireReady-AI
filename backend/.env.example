# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./hireready.db          # or postgresql://user:pass@host/db
SECRET_KEY=change-me-in-production

# ── AI Providers ─────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...                           # primary — free at console.groq.com
OPENAI_API_KEY=sk-...                          # fallback — optional

# ── Job Sources (all optional — degrade gracefully) ──────────────────────────
USAJOBS_API_KEY=                               # free at developer.usajobs.gov
USAJOBS_EMAIL=you@email.com
ADZUNA_APP_ID=                                 # free at developer.adzuna.com
ADZUNA_API_KEY=
RAPIDAPI_KEY=                                  # for JSearch (LinkedIn/Indeed/Glassdoor/ZipRecruiter)
                                               # free 200 req/mo at rapidapi.com → JSearch

# ── Auth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                              # console.cloud.google.com
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=                            # developer.linkedin.com
LINKEDIN_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000

# ── Services (all optional) ──────────────────────────────────────────────────
SENDGRID_API_KEY=                              # app.sendgrid.com — free 100 emails/day
EMAIL_FROM=noreply@hireready.ai
SENTRY_DSN=                                    # sentry.io — free tier
REDIS_URL=                                     # redis://localhost:6379 (optional, uses memory cache otherwise)

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
